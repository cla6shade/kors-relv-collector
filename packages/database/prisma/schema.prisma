generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum StationType {
  BUOY
  DRIFT_BUOY
  TIDAL
  COASTAL
  FISHING
  SPECIAL
  LIGHTHOUSE
  MARINE
  ORS
}

enum Organization {
  KHOA
  KMA
  KIOST
}

model Station {
  stn_id          String        @id
  name            String
  organization_cd Organization
  stn_type        StationType
  lat             Float?
  lon             Float?
  created_at      DateTime      @default(now())
  observations    Observation[]
  drift_positions BuoyDriftPosition[]

  @@index([stn_type])
  @@index([organization_cd])
  @@map("station")
}

model Observation {
  id              Int       @id @default(autoincrement())
  stn_id          String
  obs_cd          String
  obs_time        DateTime  @db.Timestamptz(6)
  value           Float
  unit            String
  station         Station   @relation(fields: [stn_id], references: [stn_id])

  @@unique([stn_id, obs_cd, obs_time])
  @@index([obs_cd, obs_time])
  @@map("observation_data")
}

model BuoyDriftPosition {
  id       Int      @id @default(autoincrement())
  stn_id   String
  obs_time DateTime @db.Timestamptz(6)
  lat      Float
  lon      Float
  station  Station  @relation(fields: [stn_id], references: [stn_id])

  @@unique([stn_id, obs_time])
  @@index([stn_id, obs_time])
  @@map("buoy_drift_position")
}

model StationVariable {
  id         Int      @id @default(autoincrement())
  stn_id     String
  obs_cd     String
  label      String
  unit       String
  is_enabled Boolean  @default(true)
  updated_at DateTime @updatedAt

  @@unique([stn_id, obs_cd])
  @@index([obs_cd])
  @@map("station_variable")
}
