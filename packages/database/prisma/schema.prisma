generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum StationType {
  BUOY
  TIDAL
  COASTAL
  FISHING
  SPECIAL
  LIGHTHOUSE
  MARINE
  ORS
}

enum Organization {
  KHOA
  KMA
}

model Station {
  stn_id          String        @id
  name            String
  organization_cd Organization
  stn_type        StationType
  lat             Float?
  lot             Float?
  created_at      DateTime      @default(now())
  observations    Observation[]

  @@index([stn_type])
  @@index([organization_cd])
  @@map("station")
}

model Observation {
  stn_id          String
  obs_cd          String  
  obs_time        DateTime  @db.Timestamptz(6)
  value           Float
  unit            String
  station         Station   @relation(fields: [stn_id], references: [stn_id])

  @@id([stn_id, obs_cd, obs_time])
  @@index([obs_cd, obs_time])
  @@map("observation")
}
